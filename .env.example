# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=hypertube
POSTGRES_PASSWORD=hypertube
POSTGRES_DB=hypertube
DATABASE_URL=postgresql+asyncpg://hypertube:hypertube@db:5432/hypertube

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=supersecretjwtkey_placeholder_change_me_later

# ── Frontend URL (used for OAuth redirects and password reset links) ──────────
FRONTEND_URL=http://localhost:8080

# ── 42 OAuth ──────────────────────────────────────────────────────────────────
# Register your app at https://profile.intra.42.fr/oauth/applications
FT_CLIENT_ID=your_42_client_id
FT_CLIENT_SECRET=your_42_client_secret
FT_REDIRECT_URI=http://localhost:8080/api/oauth/42/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Register your app at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/oauth/github/callback

# ── SMTP (password reset emails) ─────────────────────────────────────────────
# Leave SMTP_HOST empty to skip sending emails (token is printed to logs instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@hypertube.com

# ── Catalog Enrichment ──────────────────────────────────────────────────────
# Optional. If missing/invalid, app runs in degraded mode without OMDb enrichment.
OMDB_API_KEY=your_omdb_api_key
TMDB_API_KEY=your_tmdb_api_key

# ── Streaming Storage / Retention ───────────────────────────────────────────
TORRENT_MEDIA_DIR=/data/media
TORRENT_SUBTITLES_DIR=/data/subtitles
MEDIA_RETENTION_DAYS=30

# Internal service URL used by user-service to query torrent-service catalog API
TORRENT_SERVICE_URL=http://torrent-service:8001

# ── Torrent Providers (royalty-free / legally distributable only) ────────────
# Legal torrent source: Public Domain Torrents. Override only if the host moves.
PDT_BASE_URL=http://www.publicdomaintorrents.info
# Seconds to cache the PDT catalog listing in memory.
PDT_CATALOG_TTL=3600
